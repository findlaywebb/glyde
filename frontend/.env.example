# Same-origin serving: the app proxies `/api` → FastAPI, so the browser is always
# same-origin and needs no API base URL. The only knob is the proxy *target* — the FastAPI
# origin the `hooks.server.ts` proxy (prod) and Vite (`npm run dev`) forward to. Unset →
# http://127.0.0.1:8000.
GLYDE_API_ORIGIN=http://127.0.0.1:8000
