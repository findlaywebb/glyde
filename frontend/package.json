{
	"name": "glyde-frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"typecheck": "svelte-kit sync && tsc --noEmit",
		"gen:api": "openapi-typescript ../docs/schemas/openapi.json -o src/lib/api/schema.d.ts",
		"check:api-drift": "openapi-typescript ../docs/schemas/openapi.json -o src/lib/api/schema.d.ts --check",
		"test": "vitest run --passWithNoTests",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"boundaries": "depcruise src",
		"knip": "knip --no-exit-code"
	},
	"engines": {
		"node": ">=22.19"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^22",
		"dependency-cruiser": "^17.4.3",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.5",
		"eslint-plugin-boundaries": "^6.0.2",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"jsdom": "^29.1.1",
		"knip": "^6.16.1",
		"openapi-typescript": "7.13.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^5.6.0",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "4.1.9"
	},
	"dependencies": {
		"@lucide/svelte": "^1.22.0",
		"clsx": "^2.1.1",
		"highlight.js": "^11.11.1",
		"marked": "^18.0.5",
		"openapi-fetch": "0.17.0",
		"tailwind-merge": "^3.6.0"
	}
}
